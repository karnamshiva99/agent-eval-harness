# Copy this to .env and fill in the keys you want to use.
# At minimum you need ONE of these to run the examples.

# Groq — free tier, recommended for getting started
# https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — free tier
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI — paid
OPENAI_API_KEY=

# Anthropic — $5 signup credit
ANTHROPIC_API_KEY=
